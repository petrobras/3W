#!/bin/bash
set -exu

# If CI is unset or empty, use true as the default value
CI="${CI:-true}"

cd "$(dirname "$0")"/..

LINT="toolkit tests"
EXCLUDE_IPYNB_REGEX='\.ipynb$'
EXCLUDE_IPYNB_GLOB='*.ipynb'

# Run mypy for type checking
mypy --exclude "${EXCLUDE_IPYNB_REGEX}" ${LINT}

if [ "${CI}" = true ]; then
    # In CI, only check code formatting and linting with Ruff
    uv run black --check --extend-exclude "${EXCLUDE_IPYNB_REGEX}" ${LINT}
    uv run ruff check --extend-exclude "${EXCLUDE_IPYNB_GLOB}" ${LINT}
else
    # Locally, automatically fix formatting issues with Ruff
    uv run black --extend-exclude "${EXCLUDE_IPYNB_REGEX}" ${LINT}
    uv run ruff check --fix --extend-exclude "${EXCLUDE_IPYNB_GLOB}" ${LINT}
fi

# Links checking with lychee
if command -v lychee >/dev/null 2>&1; then
    if [ "${CI}" = true ]; then
        lychee --config lychee.toml --no-progress .
    else
        echo "Skipping link check."
    fi
else
    echo "lychee is not installed. Skipping link check."
    [ "${CI}" = true ] && exit 1
fi