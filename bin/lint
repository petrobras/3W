#!/bin/bash
set -exu

# If CI is unset or empty, use true as the default value
CI="${CI:-true}"

cd "$(dirname "$0")"/..

LINT="toolkit tests"
EXCLUDE_IPYNB='\.ipynb$'

# Run mypy for type checking
mypy --exclude "${EXCLUDE_IPYNB}" ${LINT}

if [ "${CI}" = true ]; then
    # In CI, only check code formatting and linting with Ruff
    uv run black --check --extend-exclude "${EXCLUDE_IPYNB}" ${LINT}
    uv run ruff check --extend-exclude "${EXCLUDE_IPYNB}" ${LINT}
else
    # Locally, automatically fix formatting issues with Ruff
    uv run black --extend-exclude "${EXCLUDE_IPYNB}" ${LINT}
    uv run ruff check --fix --extend-exclude "${EXCLUDE_IPYNB}" ${LINT}
fi